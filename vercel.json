{
  "version": 2,
  "builds": [
    { "src": "dashboard.html", "use": "@vercel/static" },
    { "src": "dashboard_plotly.html", "use": "@vercel/static" },
    { "src": "taiwan_market_events.md", "use": "@vercel/static" },
    { "src": "taiwan_market_cycles.md", "use": "@vercel/static" },
